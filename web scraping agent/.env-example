# Which LLM to use: openai | anthropic | google | gemini | vertex
WEB_SCRAPER_PROVIDER=openai

# Optional default model for all providers (overrides built-in defaults if set)
# WEB_SCRAPER_MODEL=gpt-4o-mini

# --- OpenAI ---
OPENAI_API_KEY=

# --- Anthropic (Claude) ---
ANTHROPIC_API_KEY=

# --- Google Gemini (Generative Language API) ---
GOOGLE_API_KEY=
# or
# GEMINI_API_KEY=

# --- Google Vertex AI ---
# Uses Application Default Credentials (gcloud auth application-default login) or service account.
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1
# aliases also supported:
# GCP_PROJECT=
# VERTEX_PROJECT=
# VERTEX_LOCATION=
